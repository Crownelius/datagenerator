{
  "name": "@crownelius/datagenerator-arxiv",
  "version": "0.4.0",
  "description": "Onboarding-driven JSONL dataset builder. Multi-source (arxiv, HF datasets, JSONL, TXT), multi-key OpenRouter (or auto-spawn from a management key), runtime REPL controls. Bundled with a Python corpus-builder under ./corpus.",
  "type": "module",
  "license": "Apache-2.0",
  "keywords": [
    "cli",
    "dataset",
    "jsonl",
    "llm",
    "openrouter",
    "arxiv",
    "multi-turn",
    "onboarding",
    "repl"
  ],
  "bin": {
    "datagen": "dist/cli.js",
    "datagenerator": "dist/cli.js",
    "datagenerator-arxiv": "dist/cli.js"
  },
  "files": [
    "dist/**",
    "examples/**",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "build:test": "tsc -p tsconfig.test.json",
    "prepack": "npm run build",
    "start": "node dist/index.js",
    "dev": "node scripts/dev.mjs",
    "test": "npm run build:test && node --test dist-test/test/**/*.test.js"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
